# ── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to git — it's already in .gitignore

# Django
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=False

# Supabase PostgreSQL  (Transaction Pooler — port 6543)
# Copy from: Supabase → Project Settings → Database → Connection string → URI
# Change [YOUR-PASSWORD] to your actual DB password
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Cloudinary image storage
# Copy from: Cloudinary Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# Set to True only on production (enables compressed static files)
USE_COMPRESSED_STATIC=True
